{
    "comments": {
        "lineComment": "//",
        "blockComment": ["/*", "*/"]
    },
    "brackets": [
        ["{", "}"],
        ["[", "]"],
        ["(", ")"]
    ],
    "autoClosingPairs": [
        ["{", "}"],
        ["[", "]"],
        ["(", ")"],
        ["\"", "\""],
        ["'", "'"],
        ["'''", "'''"],
        ["\"\"\"", "\"\"\""],
        ["{{", "}}"],
        { "open": "/*", "close": "*/", "notIn": ["string"] }
    ],
    "surroundingPairs": [
        ["{", "}"],
        ["[", "]"],
        ["(", ")"],
        ["\"", "\""],
        ["'", "'"],
        ["\"\"\"", "\"\"\""],
        ["'''", "'''"],
        ["{{", "}}"]
    ],
    "indentationRules": {
        "increaseIndentPattern": "^\\s*(json|data|urlencoded|text|files|form|multipart|fileinput)\\s*\\(.*\\{\\s*$|^\\s*>\\s*\\{%\\s*$",
        "decreaseIndentPattern": "^\\s*[}\\)]\\s*$|^\\s*%}\\s*$"
    },
    "folding": {
        "markers": {
            "start": "^\\s*(###|@name|GET|POST|PUT|DELETE|PATCH|HEAD|OPTIONS|TRACE|CONNECT)",
            "end": "^\\s*(###|@name|GET|POST|PUT|DELETE|PATCH|HEAD|OPTIONS|TRACE|CONNECT)|\\Z"
        }
    },
    "onEnterRules": [
        {
            "beforeText": "^\\s*#.*$",
            "action": {
                "indent": "none"
            }
        },
        {
            "beforeText": "^\\s*//.*$",
            "action": {
                "indent": "none"
            }
        },
        {
            "beforeText": ".*\\{\\s*$",
            "action": {
                "indentAction": "indent"
            }
        },
        {
            "beforeText": "^\\s*\\}",
            "action": {
                "indentAction": "outdent"
            }
        }
    ],
    "wordPattern": "(-?\\d*\\.\\d\\w*)|([^\\`\\~\\!\\@\\#\\%\\^\\&\\*\\(\\)\\-\\=\\+\\[\\{\\]\\}\\\\\\|\\;\\:\\'\\\"\\,\\.\\<\\>\\/\\?\\s]+)"
}