{
    "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
    "name": "dothttp-vscode",
    "fileTypes": [
        "http",
        "rest",
        "dhttp"
    ],
    "scopeName": "source.dothttp-vscode",
    "patterns": [
        {
            "include": "#comments"
        },
        {
            "include": "#import-statement"
        },
        {
            "include": "#variable-declaration"
        },
        {
            "include": "#http-request"
        },
        {
            "include": "#test-script"
        },
        {
            "include": "#keywords"
        },
        {
            "include": "#http-methods"
        },
        {
            "include": "#decorators"
        },
        {
            "include": "#template-variable"
        },
        {
            "include": "#string"
        },
        {
            "include": "#number"
        },
        {
            "include": "#constants"
        }
    ],
    "repository": {
        "comments": {
            "patterns": [
                {
                    "name": "comment.line.number-sign.dothttp",
                    "match": "#.*$"
                },
                {
                    "name": "comment.line.double-slash.dothttp",
                    "match": "//.*$"
                },
                {
                    "name": "comment.block.dothttp",
                    "begin": "/\\*",
                    "end": "\\*/",
                    "beginCaptures": {
                        "0": {
                            "name": "punctuation.definition.comment.begin.dothttp"
                        }
                    },
                    "endCaptures": {
                        "0": {
                            "name": "punctuation.definition.comment.end.dothttp"
                        }
                    }
                }
            ]
        },
        "import-statement": {
            "name": "meta.import.dothttp",
            "begin": "\\b(import)\\b",
            "end": ";",
            "beginCaptures": {
                "1": {
                    "name": "keyword.control.import.dothttp"
                }
            },
            "endCaptures": {
                "0": {
                    "name": "punctuation.terminator.statement.dothttp"
                }
            },
            "patterns": [
                {
                    "include": "#string"
                }
            ]
        },
        "variable-declaration": {
            "name": "meta.variable.declaration.dothttp",
            "begin": "\\b(var)\\b\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
            "end": ";",
            "beginCaptures": {
                "1": {
                    "name": "storage.type.var.dothttp"
                },
                "2": {
                    "name": "variable.other.declaration.dothttp"
                }
            },
            "endCaptures": {
                "0": {
                    "name": "punctuation.terminator.statement.dothttp"
                }
            },
            "patterns": [
                {
                    "match": "=",
                    "name": "keyword.operator.assignment.dothttp"
                },
                {
                    "include": "#function-call"
                },
                {
                    "include": "#interpolated-string"
                },
                {
                    "include": "#array-index"
                },
                {
                    "include": "#constants"
                },
                {
                    "include": "#number"
                },
                {
                    "include": "#string"
                },
                {
                    "include": "#template-variable"
                },
                {
                    "include": "#object"
                }
            ]
        },
        "http-request": {
            "patterns": [
                {
                    "include": "#request-name"
                },
                {
                    "include": "#request-modifiers"
                },
                {
                    "include": "#request-line"
                },
                {
                    "include": "#authentication"
                },
                {
                    "include": "#certificate"
                },
                {
                    "include": "#headers"
                },
                {
                    "include": "#query-parameters"
                },
                {
                    "include": "#request-body"
                },
                {
                    "include": "#output-redirect"
                }
            ]
        },
        "request-name": {
            "name": "meta.request.name.dothttp",
            "begin": "(@name)\\s*\\(",
            "end": "\\)",
            "beginCaptures": {
                "1": {
                    "name": "entity.name.function.decorator.dothttp"
                }
            },
            "patterns": [
                {
                    "match": ":",
                    "name": "punctuation.separator.colon.dothttp"
                },
                {
                    "include": "#string"
                },
                {
                    "name": "entity.name.tag.dothttp",
                    "match": "[a-zA-Z_][a-zA-Z0-9_]*"
                }
            ]
        },
        "request-modifiers": {
            "patterns": [
                {
                    "name": "entity.name.function.decorator.dothttp",
                    "match": "@(clear|insecure|no_parent_script)\\b"
                }
            ]
        },
        "request-line": {
            "name": "meta.http.request.line.dothttp",
            "begin": "(?:(-X)\\s+)?(GET|POST|PUT|DELETE|PATCH|HEAD|OPTIONS|TRACE|CONNECT|COPY|LINK|UNLINK|PURGE|LOCK|UNLOCK|PROPFIND|VIEW|MKCOL|MOVE|PROPPATCH|REPORT|SEARCH|curl)\\s+",
            "end": "(?=\\s*$)|(?=\\s+(basicauth|digestauth|ntlmauth|hawkauth|awsauth|azurespcert|azurespsecret|azuredevice|azurecli|certificate|p12|header|query|\\?|&|json|data|urlencoded|text|files|form|multipart|fileinput|<|output|>>|> {%))",
            "beginCaptures": {
                "1": {
                    "name": "keyword.other.curl-flag.dothttp"
                },
                "2": {
                    "name": "keyword.other.http-method.dothttp"
                }
            },
            "patterns": [
                {
                    "include": "#url"
                }
            ]
        },
        "url": {
            "patterns": [
                {
                    "name": "string.other.link.dothttp",
                    "match": "(https?://[^\\s\"'<>\\[\\]{}|\\\\^`]+|/[^\\s\"'<>\\[\\]{}|\\\\^`]*)"
                },
                {
                    "include": "#template-variable"
                },
                {
                    "include": "#string"
                }
            ]
        },
        "authentication": {
            "patterns": [
                {
                    "name": "meta.authentication.basic.dothttp",
                    "begin": "\\b(basicauth)\\s*\\(",
                    "end": "\\)",
                    "beginCaptures": {
                        "1": {
                            "name": "support.function.auth.dothttp"
                        }
                    },
                    "patterns": [
                        {
                            "include": "#auth-parameters"
                        }
                    ]
                },
                {
                    "name": "meta.authentication.digest.dothttp",
                    "begin": "\\b(digestauth)\\s*\\(",
                    "end": "\\)",
                    "beginCaptures": {
                        "1": {
                            "name": "support.function.auth.dothttp"
                        }
                    },
                    "patterns": [
                        {
                            "include": "#auth-parameters"
                        }
                    ]
                },
                {
                    "name": "meta.authentication.ntlm.dothttp",
                    "begin": "\\b(ntlmauth)\\s*\\(",
                    "end": "\\)",
                    "beginCaptures": {
                        "1": {
                            "name": "support.function.auth.dothttp"
                        }
                    },
                    "patterns": [
                        {
                            "include": "#auth-parameters"
                        }
                    ]
                },
                {
                    "name": "meta.authentication.hawk.dothttp",
                    "begin": "\\b(hawkauth)\\s*\\(",
                    "end": "\\)",
                    "beginCaptures": {
                        "1": {
                            "name": "support.function.auth.dothttp"
                        }
                    },
                    "patterns": [
                        {
                            "include": "#auth-parameters"
                        }
                    ]
                },
                {
                    "name": "meta.authentication.aws.dothttp",
                    "begin": "\\b(awsauth)\\s*\\(",
                    "end": "\\)",
                    "beginCaptures": {
                        "1": {
                            "name": "support.function.auth.dothttp"
                        }
                    },
                    "patterns": [
                        {
                            "include": "#auth-parameters"
                        }
                    ]
                },
                {
                    "name": "meta.authentication.azure.dothttp",
                    "begin": "\\b(azurespcert|azurespsecret|azuredevice|azurecli)\\s*\\(",
                    "end": "\\)",
                    "beginCaptures": {
                        "1": {
                            "name": "support.function.auth.dothttp"
                        }
                    },
                    "patterns": [
                        {
                            "include": "#auth-parameters"
                        }
                    ]
                }
            ]
        },
        "auth-parameters": {
            "patterns": [
                {
                    "name": "variable.parameter.dothttp",
                    "match": "\\b(username|password|id|key|algorithm|access_id|secret_key|service|region|session_token|tenant_id|client_id|client_secret|certificate_path|scope)\\b"
                },
                {
                    "match": "=",
                    "name": "keyword.operator.assignment.dothttp"
                },
                {
                    "match": ",",
                    "name": "punctuation.separator.comma.dothttp"
                },
                {
                    "include": "#string"
                },
                {
                    "include": "#template-variable"
                }
            ]
        },
        "certificate": {
            "patterns": [
                {
                    "name": "meta.certificate.dothttp",
                    "begin": "\\b(certificate|p12)\\s*\\(",
                    "end": "\\)",
                    "beginCaptures": {
                        "1": {
                            "name": "support.function.certificate.dothttp"
                        }
                    },
                    "patterns": [
                        {
                            "name": "variable.parameter.dothttp",
                            "match": "\\b(cert|key|file|password)\\b"
                        },
                        {
                            "match": "=",
                            "name": "keyword.operator.assignment.dothttp"
                        },
                        {
                            "match": ",",
                            "name": "punctuation.separator.comma.dothttp"
                        },
                        {
                            "include": "#string"
                        },
                        {
                            "include": "#template-variable"
                        }
                    ]
                }
            ]
        },
        "headers": {
            "patterns": [
                {
                    "name": "meta.header.function-style.dothttp",
                    "begin": "\\b(header)\\s*\\(",
                    "end": "\\)",
                    "beginCaptures": {
                        "1": {
                            "name": "support.function.header.dothttp"
                        }
                    },
                    "patterns": [
                        {
                            "include": "#function-arguments"
                        }
                    ]
                },
                {
                    "name": "meta.header.curl-style.dothttp",
                    "begin": "(-H|--header)\\s+",
                    "end": "$|(?=\\\\)",
                    "beginCaptures": {
                        "1": {
                            "name": "keyword.other.curl-flag.dothttp"
                        }
                    },
                    "patterns": [
                        {
                            "include": "#header-line"
                        }
                    ]
                },
                {
                    "name": "meta.header.colon-style.dothttp",
                    "match": "^\\s*([a-zA-Z][a-zA-Z0-9-]*)\\s*(:)\\s*(.*)$",
                    "captures": {
                        "1": {
                            "name": "entity.name.tag.http-header.dothttp"
                        },
                        "2": {
                            "name": "punctuation.separator.key-value.dothttp"
                        },
                        "3": {
                            "name": "string.unquoted.header-value.dothttp",
                            "patterns": [
                                {
                                    "include": "#template-variable"
                                }
                            ]
                        }
                    }
                }
            ]
        },
        "header-line": {
            "patterns": [
                {
                    "name": "entity.name.tag.http-header.dothttp",
                    "match": "[a-zA-Z][a-zA-Z0-9-]*(?=:)"
                },
                {
                    "name": "punctuation.separator.key-value.dothttp",
                    "match": ":"
                },
                {
                    "include": "#string"
                },
                {
                    "include": "#template-variable"
                }
            ]
        },
        "query-parameters": {
            "patterns": [
                {
                    "name": "meta.query.function-style.dothttp",
                    "begin": "\\b(query)\\s*\\(",
                    "end": "\\)",
                    "beginCaptures": {
                        "1": {
                            "name": "support.function.query.dothttp"
                        }
                    },
                    "patterns": [
                        {
                            "include": "#function-arguments"
                        }
                    ]
                },
                {
                    "name": "meta.query.shorthand.dothttp",
                    "begin": "(\\?|&)\\s*",
                    "end": "(?=\\s*$)|(?=\\s+(header|query|\\?|&|json|data|urlencoded|text|files|form|multipart|fileinput|<|output|>>|> {%))",
                    "beginCaptures": {
                        "1": {
                            "name": "keyword.operator.query.dothttp"
                        }
                    },
                    "patterns": [
                        {
                            "match": "\\(",
                            "name": "punctuation.section.parens.begin.dothttp"
                        },
                        {
                            "match": "\\)",
                            "name": "punctuation.section.parens.end.dothttp"
                        },
                        {
                            "match": "[:,=]",
                            "name": "punctuation.separator.key-value.dothttp"
                        },
                        {
                            "match": ",",
                            "name": "punctuation.separator.comma.dothttp"
                        },
                        {
                            "include": "#string"
                        },
                        {
                            "include": "#template-variable"
                        }
                    ]
                }
            ]
        },
        "request-body": {
            "patterns": [
                {
                    "name": "meta.body.json.dothttp",
                    "begin": "\\b(json)\\s*\\(",
                    "end": "\\)",
                    "beginCaptures": {
                        "1": {
                            "name": "support.function.body.dothttp"
                        }
                    },
                    "patterns": [
                        {
                            "include": "#json-content"
                        }
                    ]
                },
                {
                    "name": "meta.body.data.dothttp",
                    "begin": "\\b(data|urlencoded|text)\\s*\\(",
                    "end": "\\)",
                    "beginCaptures": {
                        "1": {
                            "name": "support.function.body.dothttp"
                        }
                    },
                    "patterns": [
                        {
                            "include": "#body-content"
                        }
                    ]
                },
                {
                    "name": "meta.body.multipart.dothttp",
                    "begin": "\\b(files|form|multipart)\\s*\\(",
                    "end": "\\)",
                    "beginCaptures": {
                        "1": {
                            "name": "support.function.body.dothttp"
                        }
                    },
                    "patterns": [
                        {
                            "include": "#file-parameters"
                        }
                    ]
                },
                {
                    "name": "meta.body.file-input.dothttp",
                    "begin": "\\b(fileinput)\\s*\\(",
                    "end": "\\)",
                    "beginCaptures": {
                        "1": {
                            "name": "support.function.body.dothttp"
                        }
                    },
                    "patterns": [
                        {
                            "include": "#function-arguments"
                        }
                    ]
                },
                {
                    "name": "meta.body.file-redirect.dothttp",
                    "begin": "<",
                    "end": "(?=\\s*$)|(?=;)",
                    "beginCaptures": {
                        "0": {
                            "name": "keyword.operator.redirect.dothttp"
                        }
                    },
                    "patterns": [
                        {
                            "match": ";",
                            "name": "punctuation.separator.semicolon.dothttp"
                        },
                        {
                            "include": "#string"
                        }
                    ]
                },
                {
                    "name": "meta.body.curl-style.dothttp",
                    "begin": "(-d|--data)\\s+",
                    "end": "(?=\\s*$)|(?=\\s+(header|query|\\?|&|output|>>|> {%))",
                    "beginCaptures": {
                        "1": {
                            "name": "keyword.other.curl-flag.dothttp"
                        }
                    },
                    "patterns": [
                        {
                            "include": "#string"
                        },
                        {
                            "include": "#triple-quote-string"
                        }
                    ]
                },
                {
                    "name": "meta.body.inline-json.dothttp",
                    "begin": "^\\s*(?=\\{|\\[)",
                    "end": "(?=^\\s*$|^\\s*###|^\\s*> {%)",
                    "patterns": [
                        {
                            "include": "source.json"
                        }
                    ]
                }
            ]
        },
        "file-parameters": {
            "patterns": [
                {
                    "match": "\\(",
                    "name": "punctuation.section.parens.begin.dothttp"
                },
                {
                    "match": "\\)",
                    "name": "punctuation.section.parens.end.dothttp"
                },
                {
                    "match": "[<:;]",
                    "name": "punctuation.separator.dothttp"
                },
                {
                    "match": ",",
                    "name": "punctuation.separator.comma.dothttp"
                },
                {
                    "include": "#string"
                },
                {
                    "include": "#triple-quote-string"
                },
                {
                    "include": "#template-variable"
                }
            ]
        },
        "output-redirect": {
            "patterns": [
                {
                    "name": "meta.output.function-style.dothttp",
                    "begin": "\\b(output)\\s*\\(",
                    "end": "\\)",
                    "beginCaptures": {
                        "1": {
                            "name": "support.function.output.dothttp"
                        }
                    },
                    "patterns": [
                        {
                            "include": "#string"
                        }
                    ]
                },
                {
                    "name": "meta.output.redirect.dothttp",
                    "begin": ">>",
                    "end": "(?=\\s*$)",
                    "beginCaptures": {
                        "0": {
                            "name": "keyword.operator.redirect.dothttp"
                        }
                    },
                    "patterns": [
                        {
                            "include": "#string"
                        }
                    ]
                }
            ]
        },
        "test-script": {
            "name": "meta.test-script.dothttp",
            "begin": ">\\s*\\{%",
            "end": "%\\}\\s*(python|javascript)?",
            "beginCaptures": {
                "0": {
                    "name": "punctuation.definition.script.begin.dothttp"
                }
            },
            "endCaptures": {
                "0": {
                    "name": "punctuation.definition.script.end.dothttp"
                },
                "1": {
                    "name": "entity.name.type.language.dothttp"
                }
            },
            "patterns": [
                {
                    "include": "source.python"
                }
            ]
        },
        "json-content": {
            "patterns": [
                {
                    "include": "#object"
                },
                {
                    "include": "#array"
                },
                {
                    "include": "#constants"
                },
                {
                    "include": "#number"
                },
                {
                    "include": "#string"
                },
                {
                    "include": "#template-variable"
                }
            ]
        },
        "body-content": {
            "patterns": [
                {
                    "include": "#object"
                },
                {
                    "include": "#string"
                },
                {
                    "include": "#triple-quote-string"
                },
                {
                    "include": "#template-variable"
                },
                {
                    "match": ",",
                    "name": "punctuation.separator.comma.dothttp"
                }
            ]
        },
        "function-arguments": {
            "patterns": [
                {
                    "match": ",",
                    "name": "punctuation.separator.comma.dothttp"
                },
                {
                    "match": "=",
                    "name": "keyword.operator.assignment.dothttp"
                },
                {
                    "include": "#string"
                },
                {
                    "include": "#template-variable"
                }
            ]
        },
        "object": {
            "name": "meta.structure.dictionary.json.dothttp",
            "begin": "\\{",
            "end": "\\}",
            "beginCaptures": {
                "0": {
                    "name": "punctuation.definition.dictionary.begin.json.dothttp"
                }
            },
            "endCaptures": {
                "0": {
                    "name": "punctuation.definition.dictionary.end.json.dothttp"
                }
            },
            "patterns": [
                {
                    "include": "#object-member"
                }
            ]
        },
        "object-member": {
            "patterns": [
                {
                    "name": "meta.structure.dictionary.key.json.dothttp",
                    "begin": "(?:([\"'])([^\"']+)\\1|([a-zA-Z_][a-zA-Z0-9_]*))\\s*(:)",
                    "end": "(?=[,}])|(?=\\n\\s*[})])",
                    "beginCaptures": {
                        "1": {
                            "name": "punctuation.definition.string.begin.json.dothttp"
                        },
                        "2": {
                            "name": "support.type.property-name.json.dothttp"
                        },
                        "3": {
                            "name": "support.type.property-name.json.dothttp"
                        },
                        "4": {
                            "name": "punctuation.separator.dictionary.key-value.json.dothttp"
                        }
                    },
                    "patterns": [
                        {
                            "include": "#json-content"
                        }
                    ]
                },
                {
                    "include": "#template-variable"
                },
                {
                    "match": ",",
                    "name": "punctuation.separator.dictionary.pair.json.dothttp"
                },
                {
                    "include": "#comments"
                }
            ]
        },
        "array": {
            "name": "meta.structure.array.json.dothttp",
            "begin": "\\[",
            "end": "\\]",
            "beginCaptures": {
                "0": {
                    "name": "punctuation.definition.array.begin.json.dothttp"
                }
            },
            "endCaptures": {
                "0": {
                    "name": "punctuation.definition.array.end.json.dothttp"
                }
            },
            "patterns": [
                {
                    "include": "#json-content"
                },
                {
                    "match": ",",
                    "name": "punctuation.separator.array.json.dothttp"
                }
            ]
        },
        "function-call": {
            "name": "meta.function-call.dothttp",
            "begin": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*\\(",
            "end": "\\)",
            "beginCaptures": {
                "1": {
                    "name": "entity.name.function.dothttp"
                }
            },
            "patterns": [
                {
                    "include": "#number"
                },
                {
                    "include": "#string"
                },
                {
                    "match": ",",
                    "name": "punctuation.separator.comma.dothttp"
                }
            ]
        },
        "array-index": {
            "name": "meta.array.index.dothttp",
            "begin": "([a-zA-Z_][a-zA-Z0-9_]*)\\s*\\[",
            "end": "\\]",
            "beginCaptures": {
                "1": {
                    "name": "variable.other.dothttp"
                }
            },
            "patterns": [
                {
                    "include": "#number"
                },
                {
                    "include": "#string"
                },
                {
                    "name": "variable.other.property.dothttp",
                    "match": "[a-zA-Z_][a-zA-Z0-9_]*"
                }
            ]
        },
        "interpolated-string": {
            "name": "string.interpolated.dothttp",
            "begin": "\\$\"",
            "end": "\"",
            "beginCaptures": {
                "0": {
                    "name": "punctuation.definition.string.begin.dothttp"
                }
            },
            "endCaptures": {
                "0": {
                    "name": "punctuation.definition.string.end.dothttp"
                }
            },
            "patterns": [
                {
                    "name": "constant.character.escape.dothttp",
                    "match": "\\\\."
                }
            ]
        },
        "template-variable": {
            "name": "variable.other.template.dothttp",
            "begin": "\\{\\{",
            "end": "\\}\\}",
            "beginCaptures": {
                "0": {
                    "name": "punctuation.definition.template-expression.begin.dothttp"
                }
            },
            "endCaptures": {
                "0": {
                    "name": "punctuation.definition.template-expression.end.dothttp"
                }
            },
            "patterns": [
                {
                    "match": "=",
                    "name": "keyword.operator.assignment.dothttp"
                },
                {
                    "include": "#string"
                },
                {
                    "name": "variable.other.readwrite.dothttp",
                    "match": "[a-zA-Z_$,:][a-zA-Z0-9_$,:]*"
                }
            ]
        },
        "string": {
            "patterns": [
                {
                    "name": "string.quoted.double.dothttp",
                    "begin": "\"",
                    "end": "\"",
                    "beginCaptures": {
                        "0": {
                            "name": "punctuation.definition.string.begin.dothttp"
                        }
                    },
                    "endCaptures": {
                        "0": {
                            "name": "punctuation.definition.string.end.dothttp"
                        }
